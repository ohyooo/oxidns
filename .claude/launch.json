{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "webui",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "webui", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "docs",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "docs", "run", "start", "--", "--port", "3100"],
      "port": 3100,
      "autoPort": true
    }
  ]
}
